{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/spark-86/hodeauxledger/blob/master/docs/schema/core/scope.genesis.schema.json",
    "title": "Core Scope Genesis",
    "type": "object",
    "required": [
        "authories"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "authories": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "policy": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "additionalProperties": false
    }
}