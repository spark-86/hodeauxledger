{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "$id": "https://github.com/spark-86/hodeauxledger/blob/master/docs/schema/core/key.assign.schema.json",
    "title": "Key Assignment Schema",
    "type": "object",
    "required": [
        "schema",
        "scope",
        "roles",
        "key"
    ],
    "properties": {
        "schema": {
            "const": "key:grant:v1"
        },
        "scope": {
            "type": "string"
        },
        "name": {
            "type": "string"
        },
        "roles": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "key": {
            "type": "string"
        },
        "exp": {
            "type": "integer"
        }
    },
    "additionalProperties": false
}